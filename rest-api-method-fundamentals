                               ("/{id}")                       ("/{id}")        ("/{id}")

RETURN TYPE       List<User>   User             User           User             String

METHOD NAME       getAllUsers  getUserById      createUser     updateUser       deleteUser

PARAMETERS        ()           (@PathVariable   (@RequestBody  (@PathVariable   (@PathVariable
                               Long id)         User user)     Long id,         Long id)
                                                               @RequestBody
                                                               User user)

